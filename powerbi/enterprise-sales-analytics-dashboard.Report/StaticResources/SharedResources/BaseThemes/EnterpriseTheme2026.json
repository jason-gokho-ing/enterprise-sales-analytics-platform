          }
        ]
      }
    },
    "stackedAreaChart": {
      "*": {
        "general": [
          {
            "responsive": true
          }
        ],
        "smallMultiplesLayout": [
          {
            "backgroundTransparency": 0,
            "gridLineType": "inner"
          }
        ]
      }
    },
    "lineClusteredColumnComboChart": {
      "*": {
        "general": [
