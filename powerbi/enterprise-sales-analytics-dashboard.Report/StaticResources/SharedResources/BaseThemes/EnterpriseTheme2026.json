    "ribbonChart": {
      "*": {
        "general": [
          {
            "responsive": true
          }
        ],
        "smallMultiplesLayout": [
          {
            "backgroundTransparency": 0,
            "gridLineType": "inner"
          }
        ],
        "valueAxis": [
          {
            "show": true
          }
        ]
      }
    },
    "hundredPercentStackedAreaChart": {
      "*": {
        "general": [
          {
            "responsive": true
          }
        ],
        "smallMultiplesLayout": [
          {
            "backgroundTransparency": 0,
            "gridLineType": "inner"
          }
        ]
      }
    },
    "group": {
      "*": {
        "background": [
          {
            "show": false
          }
        ]
      }
    },
    "basicShape": {
      "*": {
        "background": [
          {
            "show": false
          }
        ],
        "general": [
          {
            "keepLayerOrder": true
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ]
      }
    },
    "shape": {
      "*": {
        "background": [
          {
            "show": false
          }
        ],
        "general": [
          {
            "keepLayerOrder": true
          }
        ],
        "visualHeader": [
          {
            "show": false
