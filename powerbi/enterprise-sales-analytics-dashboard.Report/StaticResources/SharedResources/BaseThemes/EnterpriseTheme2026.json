          }
        ]
      }
    },
    "lineStackedColumnComboChart": {
      "*": {
        "general": [
          {
            "responsive": true
          }
        ],
        "smallMultiplesLayout": [
          {
            "backgroundTransparency": 0,
            "gridLineType": "inner"
          }
        ],
        "seriesLabels": [
          {
            "backgroundTransparency": 0.9
          }
        ]
      }
