        ]
      }
    },
    "image": {
      "*": {
        "background": [
          {
            "show": false
          }
        ],
        "general": [
          {
            "keepLayerOrder": true
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ],
        "padding": [
          {
            "left": 0,
            "top": 0,
            "right": 0,
            "bottom": 0
          }
        ]
      }
    },
    "actionButton": {
      "*": {
        "background": [
          {
            "show": false
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ]
      }
    },
    "pageNavigator": {
      "*": {
        "background": [
          {
            "show": false
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ]
      }
    },
    "bookmarkNavigator": {
      "*": {
        "background": [
          {
            "show": false
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ]
      }
    },
    "textbox": {
      "*": {
        "general": [
          {
            "keepLayerOrder": true
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ]
      }
    },
    "page": {
      "*": {
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ],
        "background": [
          {
            "transparency": 100
          }
        ]
      }
