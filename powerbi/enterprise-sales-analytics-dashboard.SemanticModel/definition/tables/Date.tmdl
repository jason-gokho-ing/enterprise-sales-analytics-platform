	partition Date = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    CALENDAR(
				        MIN('sales_analytics'[order_date]),
				        MAX('sales_analytics'[order_date])
				    ),
				    "Year", YEAR([Date]),
				    "Month Number", MONTH([Date]),
				    "Month", FORMAT([Date], "MMM"),
				    "YearMonth", FORMAT([Date], "YYYY-MM"),
				    "Quarter", "Q" & FORMAT([Date], "Q")
				)

	annotation PBI_Id = 9e3488137507461db9cf19269328deb6

